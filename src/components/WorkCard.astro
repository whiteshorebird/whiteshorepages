---
import { Image } from "astro:assets";
import type { Work } from "../data/works";

type Props = {
  work: Work;
};

const { work } = Astro.props;
---

<article class="work-card fade-in">
  <Image class="work-card__image" src={work.image} alt={work.imageAlt} width={640} height={400} format="webp" />

  <div class="work-card__body">
    <p class="work-card__category">{work.category}</p>
    <h3>{work.title}</h3>
    <p>{work.description}</p>

    <dl class="work-meta">
      <div>
        <dt>Role</dt>
        <dd>{work.role}</dd>
      </div>
      <div>
        <dt>Period</dt>
        <dd>{work.period}</dd>
      </div>
    </dl>

    <ul class="tag-list">
      {work.tags.map((tag) => <li>{tag}</li>)}
    </ul>

    {
      work.url && (
        <a class="text-link" href={work.url} target="_blank" rel="noreferrer">
          View project
        </a>
      )
    }
  </div>
</article>
